# ============================================
# BRAINIGEN — ENVIRONMENT VARIABLES
# ============================================
# Copy to .env.local and fill in. Never commit .env.local.

# ------ App ------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Brainigen
NODE_ENV=development

# ------ Supabase ------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ------ OpenAI ------
OPENAI_API_KEY=sk-your-openai-key

# ------ Anthropic (Optional) ------
ANTHROPIC_API_KEY=sk-ant-your-key

# ------ Resend ------
RESEND_API_KEY=re_your-resend-key
RESEND_FROM_EMAIL=hello@brainigen.com

# ------ Stripe (Ready but not active) ------
STRIPE_SECRET_KEY=sk_test_your-stripe-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# ------ Upstash Redis (Rate Limiting) ------
UPSTASH_REDIS_REST_URL=https://your-region.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ------ Analytics ------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=brainigen.com

# ------ Sentry (Optional) ------
SENTRY_DSN=https://your-sentry-dsn
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ------ Admin ------
ADMIN_EMAIL=musbabaff@brainigen.com
