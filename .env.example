# ============================================================
# BRAINIGEN — MINIMAL REQUIRED .env
# ============================================================
# Only these 4 variables are REQUIRED for the platform to run.
# Everything else is managed via the Admin Panel:
#   /admin/system/settings
#
# After first deploy, go to /admin/system/settings and enter
# your API keys there — they will be stored encrypted in the
# database via site_settings table.
# ============================================================

# --- REQUIRED: Supabase (infrastructure, cannot be in DB) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# --- REQUIRED: Encryption key for site_settings secrets ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_KEY=your_64_char_hex_string_here

# ============================================================
# OPTIONAL BOOTSTRAP VALUES
# These are used as fallbacks if not yet set in the admin panel.
# Once set via /admin/system/settings, these can be removed.
# ============================================================

# Resend (Email) — set via Admin > System > Settings > Email tab
# RESEND_API_KEY=re_...

# OpenAI — set via Admin > System > Settings > OpenAI tab
# OPENAI_API_KEY=sk-...

# Stripe — set via Admin > System > Settings > Stripe tab
# STRIPE_SECRET_KEY=sk_...
# STRIPE_PUBLISHABLE_KEY=pk_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Upstash Redis (Rate Limiting) — set via Admin > System > Settings > Rate Limiting tab
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# ============================================================
# PUBLIC/BUILD-TIME (safe to commit to .env.example)
# ============================================================
NEXT_PUBLIC_APP_URL=https://brainigen.com
